{
  "name": "tonquant",
  "version": "0.1.0",
  "description": "AI-native quant research CLI for the TON blockchain",
  "type": "module",
  "bin": {
    "tonquant": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/quant-backend.js",
    "README.md"
  ],
  "keywords": [
    "ton",
    "defi",
    "quant",
    "trading",
    "cli",
    "ai-agent",
    "backtest",
    "stonfi",
    "blockchain"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ancienttwo/ton-quant"
  },
  "homepage": "https://tonquant.com",
  "license": "MIT",
  "author": "ancienttwo",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build-package.ts",
    "pack:smoke": "bun run scripts/smoke-pack.ts",
    "prepack": "bun run build",
    "test": "bun test tests/",
    "test:coverage": "bun test --coverage tests/"
  },
  "devDependencies": {
    "@tonquant/core": "workspace:*",
    "@types/bun": "latest",
    "chalk": "latest",
    "cli-table3": "latest",
    "commander": "^13",
    "zod": "^3.24"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
