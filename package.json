{
  "name": "tonquant",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tonquant": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@ton/core": "latest",
    "@ton/crypto": "latest",
    "@ton/ton": "latest",
    "chalk": "latest",
    "cli-table3": "latest",
    "commander": "^13",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
