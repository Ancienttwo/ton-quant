{
  "name": "tonquant-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter tonquant dev",
    "build": "bun run --filter tonquant build",
    "typecheck": "tsc -b packages/core/tsconfig.json apps/cli/tsconfig.json apps/quant-backend/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test --max-concurrency 1 --path-ignore-patterns '_ref/**'",
    "test:coverage": "bun test --coverage --max-concurrency 1 --path-ignore-patterns '_ref/**'"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "bun-types": "^1.3.11",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
